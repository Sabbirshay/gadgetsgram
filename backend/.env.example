# Gadgets Gram Backend Configuration
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Database — SQLite for local dev
DB_TYPE=sqlite
DB_DATABASE=./data/gadgets-gram.db

# Database — PostgreSQL for production (uncomment and fill in for Supabase/Render)
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@host:5432/database

# Supabase (optional — required only if using Supabase client SDK features)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-service-role-key

# Cloudinary (optional — for image uploads)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Admin seed
ADMIN_EMAIL=admin@gadgetsgram.com
ADMIN_PASSWORD=Admin@123456

# API
API_PREFIX=api/v1
# For production, use comma-separated origins:
# CORS_ORIGIN=https://gadgetsgram.vercel.app,http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

